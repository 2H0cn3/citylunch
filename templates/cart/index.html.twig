{% extends 'base.html.twig' %}
{% block title %}Mon panier{% endblock %}
{% block body %}
    <h1 class="mb-4">Mon panier</h1>

    {% if cart.items is empty %}
        <p>Votre panier est vide. <a href="{{ path('app_home') }}">Retour au menu</a></p>
    {% else %}
        <table class="table align-middle">
            <thead>
                <tr><th>Produit</th><th>Prix</th><th>Quantité</th><th>Total</th><th></th></tr>
            </thead>
            <tbody>
            {% for line in cart.items %}
                <tr>
                    <td>{{ line.product.name }}</td>
                    <td>{{ line.product.price }} €</td>
                    <td>
                        <form method="post" action="{{ path('app_cart_update', {id: line.product.id}) }}" class="d-flex gap-2">
                            <input type="number" name="qty" value="{{ line.qty }}" min="1"
                                   class="form-control form-control-sm" style="width:80px">
                            <button class="btn btn-sm btn-outline-secondary">MAJ</button>
                        </form>
                    </td>
                    <td>{{ line.lineTotal|number_format(2, '.', ' ') }} €</td>
                    <td>
                        <form method="post" action="{{ path('app_cart_remove', {id: line.product.id}) }}">
                            <button class="btn btn-sm btn-danger">Retirer</button>
                        </form>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="3" class="text-end">Total</th>
                    <th>{{ cart.total|number_format(2, '.', ' ') }} €</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    {% endif %}
{% endblock %}